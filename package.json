{
  "name": "@synetics/vite-plugin",
  "version": "0.7.0-alpha",
  "description": "Vite plugin for the Synetics framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "pulsar",
    "vite",
    "plugin",
    "build-tool"
  ],
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "dependencies": {
    "@synetics/transformer": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "typescript": "^5.9.3"
  },
  "author": "Tadeo Piana <https://www.linkedin.com/in/tadeopiana/>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/binaryjack/synetics-vite-plugin.git"
  },
  "homepage": "https://github.com/binaryjack/synetics-vite-plugin#readme",
  "bugs": {
    "url": "https://github.com/binaryjack/synetics-vite-plugin/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
